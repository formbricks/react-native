    "expo": "55.0.9",
    "expo-status-bar": "55.0.4",
    "react": "19.2.4",
    "react-native": "0.84.1",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@types/react": "19.2.14",
    "typescript": "6.0.2"
  },
  "private": true
}
